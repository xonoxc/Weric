---
import DemoAnimation from "./DemoAnimation.tsx"
---

<section class="section-padding overflow-hidden">
  <div class="container-main">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-medium text-text-tertiary uppercase tracking-widest mb-4">See It In Action</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
        Ask. Explore. <span class="text-text-secondary">Understand.</span>
      </h2>
    </div>

    <div class="mt-12 max-w-2xl mx-auto">
      <DemoAnimation client:visible />
    </div>
  </div>
</section>
