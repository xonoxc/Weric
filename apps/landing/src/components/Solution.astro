---
---

<section class="section-padding bg-bg-secondary">
  <div class="container-main">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-medium text-text-tertiary uppercase tracking-widest mb-4">The Solution</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
        From scattered sources<br />
        <span class="text-text-secondary">to connected stories.</span>
      </h2>
    </div>

    <div class="mt-16 grid md:grid-cols-2 gap-8 md:gap-16 max-w-4xl mx-auto">
      <div class="p-6 rounded-xl bg-surface border border-border">
        <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-4">Before</p>
        <div class="space-y-3">
          <div class="p-3 rounded-lg bg-bg-tertiary border border-border">
            <p class="text-sm text-text-secondary">Reddit thread</p>
          </div>
          <div class="p-3 rounded-lg bg-bg-tertiary border border-border">
            <p class="text-sm text-text-secondary">GitHub discussion</p>
          </div>
          <div class="p-3 rounded-lg bg-bg-tertiary border border-border">
            <p class="text-sm text-text-secondary">Documentation</p>
          </div>
          <div class="p-3 rounded-lg bg-bg-tertiary border border-border">
            <p class="text-sm text-text-secondary">Blog post</p>
          </div>
        </div>
      </div>

      <div class="p-6 rounded-xl bg-surface border border-border">
        <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-4">After</p>
        <div class="space-y-3">
          <div class="p-3 rounded-lg bg-accent-muted border border-accent/30">
            <p class="text-sm font-medium text-accent">Connected Story</p>
            <p class="text-xs text-text-secondary mt-1">Merged from 14 sources across the internet</p>
          </div>
          <div class="flex items-center gap-2 pl-4">
            <div class="w-px h-8 bg-border" />
          </div>
          <div class="p-3 rounded-lg bg-bg-tertiary border border-border ml-4">
            <p class="text-xs text-text-secondary">Reddit · GitHub · Docs · Blog</p>
          </div>
          <div class="flex items-center gap-2 pl-4">
            <div class="w-px h-8 bg-border" />
          </div>
          <div class="p-3 rounded-lg bg-bg-tertiary border border-border ml-8">
            <p class="text-xs text-text-secondary">Timeline · Analysis · Sources</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
