---
---

<section class="section-padding bg-bg-secondary">
  <div class="container-main">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-medium text-text-tertiary uppercase tracking-widest mb-4">Architecture</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
        How Weric works.<br />
        <span class="text-text-secondary">From question to knowledge.</span>
      </h2>
    </div>

    <div class="mt-16 flex flex-col items-center gap-0 max-w-md mx-auto">
      {["You Ask", "AI Search Agent", "Story Engine", "Knowledge Graph", "Personalized Internet"].map((step, i) => (
        <div class="flex flex-col items-center">
          <div class="w-32 h-32 rounded-full border border-border bg-surface flex items-center justify-center">
            <span class="text-sm font-medium text-text-primary text-center leading-snug px-2">{step}</span>
          </div>
          {i < 4 && (
            <div class="w-px h-8 bg-border" />
          )}
        </div>
      ))}
    </div>
  </div>
</section>
