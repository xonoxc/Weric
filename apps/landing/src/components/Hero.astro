---
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <div class="container-main relative z-10 grid lg:grid-cols-2 gap-12 lg:gap-24 pt-24 pb-16">
    <div class="flex flex-col justify-center">
      <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-tight">
        <span class="block">Defragment</span>
        <span class="block text-text-secondary">The Internet.</span>
      </h1>
      <p class="mt-6 text-lg text-text-secondary leading-relaxed max-w-md">
        Weric transforms scattered posts, articles, documentation, research and discussions into connected knowledge.
      </p>
      <div class="mt-10 flex items-center gap-4">
        <a href="/signup" class="inline-flex items-center justify-center px-6 py-3 text-sm font-medium text-white bg-accent hover:bg-accent-hover rounded-md transition-all duration-200">
          Start Exploring
        </a>
        <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 text-sm font-medium text-text-secondary border border-border hover:border-border-hover hover:text-text-primary rounded-md transition-all duration-200">
          GitHub
        </a>
      </div>
    </div>

    <div class="hidden lg:flex items-center justify-center">
      <div class="relative w-full aspect-square max-w-[500px]">
        <div class="absolute inset-0 rounded-2xl border border-border bg-surface overflow-hidden">
          <div class="p-4 space-y-3">
            <div class="flex items-center gap-2 text-xs text-text-tertiary px-2">
              <span class="w-2 h-2 rounded-full bg-accent" />
              <span>Knowledge Canvas</span>
            </div>
            <div class="space-y-2">
              <div class="p-3 rounded-lg bg-bg-secondary border border-border">
                <div class="text-xs font-medium text-text-primary">LangGraph v2 Released</div>
                <div class="text-xs text-text-tertiary mt-1">Native streaming. Checkpointing.</div>
                <div class="flex items-center gap-3 mt-2 text-xs text-text-tertiary">
                  <span>31 sources</span>
                  <span class="text-accent">94%</span>
                </div>
              </div>
              <div class="p-3 rounded-lg bg-bg-secondary border border-border">
                <div class="text-xs font-medium text-text-primary">MCP Gains Traction</div>
                <div class="text-xs text-text-tertiary mt-1">Standardized context protocol.</div>
                <div class="flex items-center gap-3 mt-2 text-xs text-text-tertiary">
                  <span>18 sources</span>
                  <span class="text-accent">87%</span>
                </div>
              </div>
              <div class="p-3 rounded-lg bg-bg-secondary border border-border">
                <div class="text-xs font-medium text-text-primary">Rust 2026 Edition</div>
                <div class="text-xs text-text-tertiary mt-1">Async improvements. Traits.</div>
                <div class="flex items-center gap-3 mt-2 text-xs text-text-tertiary">
                  <span>24 sources</span>
                  <span class="text-accent">91%</span>
                </div>
              </div>
            </div>
            <div class="flex items-center justify-center gap-1 pt-2">
              <div class="w-1.5 h-1.5 rounded-full bg-accent" />
              <div class="w-1.5 h-1.5 rounded-full bg-text-tertiary" />
              <div class="w-1.5 h-1.5 rounded-full bg-text-tertiary" />
            </div>
          </div>
        </div>
        <div class="absolute -top-3 -right-3 w-20 h-20 bg-accent/10 rounded-full blur-3xl" />
        <div class="absolute -bottom-6 -left-6 w-32 h-32 bg-accent/5 rounded-full blur-3xl" />
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-bg to-transparent pointer-events-none" />
</section>
