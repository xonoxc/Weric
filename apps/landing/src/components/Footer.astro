---
const sections = [
  {
    title: "Product",
    links: [
      { label: "Docs", href: "#" },
      { label: "Blog", href: "#" },
      { label: "Status", href: "#" },
      { label: "API", href: "#" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "GitHub", href: "https://github.com" },
      { label: "Changelog", href: "#" },
      { label: "Documentation", href: "#" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "Discord", href: "#" },
      { label: "Twitter", href: "#" },
      { label: "Email", href: "#" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Privacy", href: "#" },
      { label: "Terms", href: "#" },
      { label: "OSS Licenses", href: "#" },
    ],
  },
]
---

<footer class="border-t border-border">
  <div class="container-main py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <div class="col-span-2 md:col-span-1">
        <span class="text-sm font-semibold tracking-tight text-text-primary">WERIC</span>
        <p class="mt-2 text-xs text-text-tertiary leading-relaxed max-w-[200px]">
          An AI-powered browser for internet knowledge.
        </p>
      </div>
      {sections.map(s => (
        <div>
          <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">{s.title}</h4>
          <ul class="space-y-2">
            {s.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-text-secondary hover:text-text-primary transition-colors duration-200"
                  target={link.href.startsWith("http") ? "_blank" : undefined}
                  rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-12 pt-6 border-t border-border flex items-center justify-between">
      <p class="text-xs text-text-tertiary">&copy; {new Date().getFullYear()} Weric. All rights reserved.</p>
    </div>
  </div>
</footer>
