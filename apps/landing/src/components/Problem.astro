<section class="section-padding">
  <div class="container-main">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-medium text-text-tertiary uppercase tracking-widest mb-4">The Problem</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-tight">
        The internet wasn't designed<br />
        <span class="text-text-secondary">for understanding.</span>
      </h2>
    </div>

    <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
      <div class="p-4 rounded-lg bg-surface border border-border text-center">
        <p class="text-sm font-medium text-text-primary">Reddit</p>
      </div>
      <div class="p-4 rounded-lg bg-surface border border-border text-center">
        <p class="text-sm font-medium text-text-primary">Twitter</p>
      </div>
      <div class="p-4 rounded-lg bg-surface border border-border text-center">
        <p class="text-sm font-medium text-text-primary">Medium</p>
      </div>
      <div class="p-4 rounded-lg bg-surface border border-border text-center">
        <p class="text-sm font-medium text-text-primary">GitHub</p>
      </div>
      <div class="p-4 rounded-lg bg-surface border border-border text-center">
        <p class="text-sm font-medium text-text-primary">Docs</p>
      </div>
      <div class="p-4 rounded-lg bg-surface border border-border text-center">
        <p class="text-sm font-medium text-text-primary">Blogs</p>
      </div>
      <div class="p-4 rounded-lg bg-surface border border-border text-center">
        <p class="text-sm font-medium text-text-primary">YouTube</p>
      </div>
      <div class="p-4 rounded-lg bg-surface border border-border text-center">
        <p class="text-sm font-medium text-text-primary">Papers</p>
      </div>
    </div>

    <div class="mt-12 text-center max-w-xl mx-auto">
      <p class="text-lg text-text-secondary leading-relaxed">
        Information lives everywhere. <span class="text-text-primary">Context lives nowhere.</span>
      </p>
    </div>
  </div>
</section>
