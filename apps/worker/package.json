{
  "name": "@weric/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "start": "bun run dist/index.js",
    "check-types": "tsc --noEmit",
    "lint": "echo 'no linter configured'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@weric/contracts": "workspace:*",
    "@weric/database": "workspace:*",
    "@weric/story-engine": "workspace:*",
    "@weric/recommendation": "workspace:*",
    "@weric/browser": "workspace:*",
    "@weric/ai": "workspace:*",
    "@weric/shared": "workspace:*",
    "@weric/config": "workspace:*",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@types/bun": "^1.2.0",
    "typescript": "5.9.2",
    "vitest": "^3.1.0"
  }
}
